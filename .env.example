# ── Banco de dados ─────────────────────────────────────────────────────────────
DB_USER=tcc
DB_PASSWORD=troque_esta_senha
DB_PRINCIPAL_NAME=tcc_principal
DB_BOLO_NAME=tcc_bolo

# ── Portas dos serviços ────────────────────────────────────────────────────────
SERVIDOR_PORT=8080
BOLO_PORT=8081
GOVERNANCA_PORT=8090

# ── Coletor (simulador ALPR) ───────────────────────────────────────────────────
CAMERA_ID=CAM-SIM-001
KEY_MONTH=2026-06

# ── Coletor — chaves obtidas do servidor de governança no startup ──────────────
# K_GOV_HEX=<hex 32 bytes — GET /keys/kgov com X-Camera-Key>
# MONTHLY_PK_HEX=<hex 32 bytes — GET /keys/monthly-pk>

# ── Governança ─────────────────────────────────────────────────────────────────
JUDGE_SK_PATH=/run/secrets/judge.pem
MONTHLY_KEY_PATH=/run/secrets/monthly.key
KGOV_PATH=/run/secrets/kgov.bin
KEY_PASSPHRASE=troque_esta_passphrase
CAMERA_API_KEY=troque_esta_chave_de_camera
INVESTIGATOR_API_KEY=troque_esta_chave_de_investigador

# ── Servidor de custódia ────────────────────────────────────────────────────────
JUDGE_PK_PATH=/run/secrets/judge.pub.pem
